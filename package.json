{
  "name": "store",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "concurrently --kill-others --names \"apps,stripe\" --prefix-colors \"cyan,yellow\" \"turbo run dev\" \"stripe listen --forward-to localhost:4000/api/webhooks/stripe\"",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @store/db run db:generate",
    "db:migrate": "pnpm --filter @store/db run db:migrate",
    "db:studio": "pnpm --filter @store/db run db:studio",
    "stripe:listen": "stripe listen --forward-to localhost:4000/api/webhooks/stripe"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
