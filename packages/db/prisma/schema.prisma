generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum DeliveryMethod {
  COURIER
  PARCEL_LOCKER
}

enum ReturnStatus {
  RETURN_REQUESTED
  RETURN_APPROVED
  REFUNDED
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String?
  googleId       String?  @unique
  role           Role     @default(USER)
  refreshToken   String?
  firstName      String?
  lastName       String?
  phone          String?
  defaultAddress Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  carts          Cart[]
  orders         Order[]
}

model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  imageUrl String?
  parentId String?
  parent   Category?  @relation("Subcategories", fields: [parentId], references: [id])
  children Category[] @relation("Subcategories")
  products Product[]
}

model Product {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  /// Short one-liner shown above the fold, near the price
  shortDescription  String?
  /// Long-form product description in markdown (rendered with sanitization on the storefront)
  description       String?
  /// Bulleted highlights shown next to the price (e.g. ["27\" 4K matryca", "144 Hz", "USB-C 90W"])
  keyFeatures       String[]         @default([])
  /// Free-form key-value specs table (e.g. { "Rozdzielczość": "3840×2160", "Gniazda": "HDMI 2.1, DP" })
  specifications    Json?
  basePrice         Decimal          @db.Decimal(10, 2)
  isActive          Boolean          @default(true)
  categoryId        String
  category          Category         @relation(fields: [categoryId], references: [id])
  /// Which variant attribute key drives gallery swapping (e.g. "Kolor"). Null = single gallery shared by all variants.
  imageAttributeKey String?
  viewCount         Int              @default(0)
  variants          ProductVariant[]
  images            ProductImage[]
  priceHistory      PriceHistory[]
  reviews           Review[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([categoryId])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorName String
  rating     Int
  comment    String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([productId, approved])
}

model ProductVariant {
  id                 String              @id @default(cuid())
  productId          String
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku                String              @unique
  price              Decimal             @db.Decimal(10, 2)
  compareAtPrice     Decimal?            @db.Decimal(10, 2)
  stock              Int                 @default(0)
  attributes         Json
  isActive           Boolean             @default(true)
  cartItems          CartItem[]
  orderItems         OrderItem[]
  priceHistory       PriceHistory[]
  stockNotifications StockNotification[]
}

model StockNotification {
  id         String          @id @default(cuid())
  variantId  String
  variant    ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  email      String
  createdAt  DateTime        @default(now())
  notifiedAt DateTime?

  @@unique([variantId, email])
  @@index([variantId, notifiedAt])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  position  Int     @default(0)
  /// Bound to a specific value of Product.imageAttributeKey (e.g. "Czerwony"). Null = default/fallback image shown when no variant-specific image exists.
  attributeValue String?

  @@index([productId])
  @@index([productId, attributeValue])
}

/// Omnibus Directive — tracks price per variant for 30-day lowest price display
model PriceHistory {
  id         String         @id @default(cuid())
  productId  String
  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  price      Decimal        @db.Decimal(10, 2)
  recordedAt DateTime       @default(now())

  @@index([variantId, recordedAt])
  @@index([productId])
}

model Cart {
  id                  String     @id @default(cuid())
  userId              String?
  user                User?      @relation(fields: [userId], references: [id])
  sessionId           String?
  items               CartItem[]
  recoveryEmailSentAt DateTime?
  updatedAt           DateTime   @updatedAt

  @@index([userId])
  @@index([sessionId])
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int

  @@index([variantId])
}

model Coupon {
  id           String        @id @default(cuid())
  code         String        @unique
  type         DiscountType
  value        Decimal       @db.Decimal(10, 2)
  expiresAt    DateTime?
  minOrderValue Decimal?     @db.Decimal(10, 2)
  maxUses      Int?
  limitPerUser Int?
  usedCount    Int           @default(0)
  isActive     Boolean       @default(true)
  usages       CouponUsage[]
  orders       Order[]
  createdAt    DateTime      @default(now())
}

model CouponUsage {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id])
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  userId     String?
  guestEmail String?
  usedAt     DateTime @default(now())

  @@index([couponId, userId])
}

model Order {
  id              String        @id @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestEmail      String?
  guestName       String?
  guestPhone      String?
  status          OrderStatus   @default(PENDING_PAYMENT)
  subtotal        Decimal       @db.Decimal(10, 2)
  discountAmount  Decimal       @db.Decimal(10, 2) @default(0)
  total           Decimal       @db.Decimal(10, 2)
  couponId        String?
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  shippingAddress  Json
  billingAddress   Json?
  deliveryMethod   DeliveryMethod @default(COURIER)
  lockerCode            String?
  shippingPointDetails  Json?
  wantsInvoice     Boolean        @default(false)
  companyName      String?
  taxId            String?
  invoiceUrl       String?
  fakturowniaId    String?
  stripeSessionId  String?
  inpostShipmentId String?
  trackingNumber   String?
  shippingLabelUrl String?
  items            OrderItem[]
  couponUsage      CouponUsage[]
  returnRequest    ReturnRequest?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([userId])
  @@index([status])
}

model ReturnRequest {
  id          String       @id @default(cuid())
  orderId     String       @unique
  order       Order        @relation(fields: [orderId], references: [id])
  reason      String
  bankAccount String
  status      ReturnStatus @default(RETURN_REQUESTED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
}

model StoreSettings {
  id                   Int     @id @default(1)
  ga4Id                String?
  fbPixelId            String?
  termsOfService       String  @default("")
  privacyPolicy        String  @default("")
  showQuantitySelector Boolean @default(true)
  showStockBadge       Boolean @default(true)
  showReviews          Boolean @default(true)
  showBestsellers      Boolean @default(true)
  enableGuestCheckout  Boolean @default(true)
}

model OrderItem {
  id                String         @id @default(cuid())
  orderId           String
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId         String
  variant           ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  quantity          Int
  priceAtPurchase   Decimal        @db.Decimal(10, 2)
  productName       String
  variantSku        String
  variantAttributes Json

  @@index([orderId])
}
